# Example environment variables for local development
# Copy this file to .env and fill values (do NOT commit secrets).
# For Expo Go on a physical device, set EXPO_PUBLIC_SUPABASE_URL to your Mac LAN IP (e.g. http://192.168.1.10:54329).
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54329
# EXPO_PUBLIC_SUPABASE_URL=http://<YOUR_MAC_LAN_IP>:54329
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_SUPABASE_STORAGE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_API_URL=http://127.0.0.1:54329
EXPO_TOKEN=
# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_STORAGE_ANON_KEY=your-publishable-storage-key

# API Configuration
EXPO_PUBLIC_API_URL=https://your-api.com

# Expo/EAS
EXPO_TOKEN=your-expo-token-for-ci-cd

# iOS/Android specific (optional)
EXPO_IOS_BUNDLE_IDENTIFIER=com.elegance.driver
EXPO_ANDROID_PACKAGE=com.elegance.driver
