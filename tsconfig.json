{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "jsx": "react-native",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["jest", "react-native"],
    "baseUrl": "."
  },
  "include": ["app", "src", "components", "nativewind-env.d.ts"],
  "exclude": ["node_modules"]
}
